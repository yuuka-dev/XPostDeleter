# ChromeDriver のパス（省略時はカレントディレクトリの chromedriver.exe を使用）
# CHROME_DRIVER_PATH=C:\path\to\chromedriver.exe

# Chrome ユーザーデータディレクトリ（省略時はデフォルト値を使用）
USER_DATA_DIR=C:\Users\YourName\AppData\Local\Google\Chrome\User Data

# --- テキスト解析 LLM API キー ---
# Gemini（Google AI Studio で取得: https://aistudio.google.com/apikey）
GEMINI_API_KEY=your_gemini_api_key_here

# Claude（Anthropic Console で取得: https://console.anthropic.com/）
# Gemini でグレー判定になったツイートのみ使用（オプション）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
